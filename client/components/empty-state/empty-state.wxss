.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.6;
}
