<view class="bill-card" bindtap="onTap" bindlongpress="onLongPress">
  <view class="bill-left">
    <view class="bill-icon">{{bill.categoryIcon || '📦'}}</view>
    <view class="bill-info">
      <view class="bill-category">{{bill.categoryName || '未分类'}}</view>
      <view class="bill-meta">
        <text class="bill-remark">{{bill.remark || '无备注'}}</text>
        <text wx:if="{{showSource}}" class="tag {{sourceClass}}">{{sourceText}}</text>
      </view>
    </view>
  </view>
  <view class="bill-right">
    <view class="bill-amount {{amountClass}}">{{displayAmount}}</view>
    <view wx:if="{{showDate}}" class="bill-time text-light text-sm">{{displayTime}}</view>
  </view>
</view>
