.page-container {
  padding: 20rpx 30rpx 40rpx;
}

.user-section {
  flex-direction: column;
  padding: 40rpx 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #F0F4FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
}

.user-stats {
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.setting-item {
  padding: 20rpx 0;
  min-height: 56rpx;
}

.setting-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.setting-icon {
  font-size: 32rpx;
  width: 40rpx;
  text-align: center;
}

.setting-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-success {
  background: #F6FFED;
  color: #52C41A;
  border: 2rpx solid #B7EB8F;
}

.picker-value {
  font-size: 24rpx;
  color: #6B7280;
}
