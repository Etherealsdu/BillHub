.page-container {
  padding: 20rpx 30rpx;
}

.filter-bar {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: #F5F7FA;
  color: #6B7280;
  border: 2rpx solid transparent;
}

.filter-tag.active {
  background: #F0F4FF;
  color: #4A90D9;
  border-color: #4A90D9;
}

.filter-tag:active {
  opacity: 0.7;
}

.clear-btn {
  background: #FFF2F0;
  color: #FF4D4F;
  border-color: transparent;
}

.dot-red, .dot-green {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
}

.dot-red { background: #FF4D4F; }
.dot-green { background: #52C41A; }

.action-btn {
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #F0F4FF;
  color: #4A90D9;
  border: 2rpx solid #D6E4FF;
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn.danger {
  background: #FFF2F0;
  color: #FF4D4F;
  border-color: #FFCCC7;
}

.filter-panel {
  margin-bottom: 16rpx;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #6B7280;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  width: calc(20% - 16rpx);
  padding: 12rpx 0;
  border-radius: 12rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
}

.cat-item.active {
  background: #F0F4FF;
  border-color: #4A90D9;
}

.cat-icon {
  font-size: 36rpx;
}

.cat-name {
  font-size: 20rpx;
  color: #6B7280;
}

.bill-list {
  min-height: 40vh;
}

.bill-items {
  padding: 8rpx 24rpx;
}

.skeleton-list {
  padding: 20rpx 0;
}

.skeleton-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.skeleton-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
}

.skeleton-line {
  height: 24rpx;
}

.w-60 { width: 60%; }
.w-40 { width: 40%; }
.w-30 { width: 30%; }
