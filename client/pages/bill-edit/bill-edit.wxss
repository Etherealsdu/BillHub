.page-container {
  padding: 20rpx 30rpx;
}

.type-selector {
  gap: 16rpx;
  justify-content: center;
  padding: 24rpx;
}

.type-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  background: #F5F7FA;
  font-size: 24rpx;
  color: #6B7280;
  flex: 1;
}

.type-btn.active {
  color: #FFFFFF;
}

.type-btn.active.expense { background: #FF4D4F; }
.type-btn.active.income { background: #52C41A; }
.type-btn.active.transfer { background: #4A90D9; }

.type-btn:active {
  opacity: 0.8;
}

.type-icon {
  font-size: 32rpx;
}

.amount-section {
  text-align: center;
  padding: 32rpx 24rpx;
  margin-top: 20rpx;
}

.amount-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.currency-symbol {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.amount-input {
  font-size: 72rpx;
  font-weight: 700;
  color: #1A1A2E;
  text-align: left;
  width: 400rpx;
  height: 100rpx;
  line-height: 100rpx;
}

.form-card {
  margin-top: 20rpx;
  padding: 8rpx 24rpx;
}

.form-row {
  padding: 24rpx 0;
  min-height: 48rpx;
}

.form-label {
  font-size: 28rpx;
  color: #6B7280;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.form-value {
  font-size: 28rpx;
  color: #1A1A2E;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.form-cat-icon {
  font-size: 28rpx;
}

.form-cat-name {
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.save-btn {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx;
  font-size: 30rpx;
}

.delete-btn {
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  padding: 20rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
}

/* Category Picker */
.category-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  max-height: 60vh;
  overflow-y: auto;
  padding: 30rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.picker-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
}

.picker-close {
  font-size: 32rpx;
  color: #9CA3AF;
  padding: 8rpx;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: calc(25% - 20rpx);
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.picker-item.active {
  background: #F0F4FF;
  border-color: #4A90D9;
}

.picker-item:active {
  opacity: 0.7;
}

.picker-icon {
  font-size: 40rpx;
}

.picker-name {
  font-size: 22rpx;
  color: #6B7280;
}
