.page-container {
  padding: 30rpx;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-card {
  height: 160rpx;
  border-radius: 16rpx;
}

.family-header {
  flex-direction: column;
  padding: 40rpx;
  gap: 12rpx;
}

.family-icon {
  font-size: 80rpx;
}

.family-name {
  font-size: 36rpx;
  font-weight: 600;
}

.invite-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-box {
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: #F0F4FF;
  border-radius: 12rpx;
  margin-top: 12rpx;
  min-width: 240rpx;
}

.code-text {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #4A90D9;
  font-family: monospace;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.member-item {
  padding: 20rpx 0;
}

.member-left {
  gap: 16rpx;
}

.member-avatar {
  font-size: 40rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F4FF;
  border-radius: 30rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
}

.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  margin-bottom: 60rpx;
}

.action-row {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  z-index: 1000;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
  justify-content: center;
}

.setting-item {
  padding: 20rpx 0;
  justify-content: center;
}
