<view class="empty-state">
  <view class="empty-icon">{{icon}}</view>
  <view class="empty-title">{{title}}</view>
  <view wx:if="{{description}}" class="empty-desc">{{description}}</view>
  <button wx:if="{{showAction}}" class="btn-primary btn-small mt-20" bindtap="onAction">{{actionText}}</button>
</view>
