.stat-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-card.compact {
  padding: 20rpx 16rpx;
}

.stat-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.stat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #F0F0F0;
  margin: 0 10rpx;
}
